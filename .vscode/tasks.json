{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: gcc Aktive Datei kompilieren",
            "type": "process",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "C/C++: clang (MSYS2 CLANGARM64) Aktive Datei kompilieren",
            "type": "process",
            "command": "C:\\msys64\\clangarm64\\bin\\clang.exe",
            "args": [
                "-fcolor-diagnostics",
