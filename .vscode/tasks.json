{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build (gcc ucrt64)",
      "type": "process",
      "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
      "args": [
        "-g",
        "-Wall",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}